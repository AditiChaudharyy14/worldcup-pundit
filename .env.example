# Used by app/pundit.py (Anthropic Messages API for AI commentary).
# Copy to .env (gitignored) and fill in your key. Never commit .env.
ANTHROPIC_API_KEY=

# Used by app/bot.py (Discord bot). Never commit .env.
# Bot token: Discord Developer Portal -> your app -> Bot -> Reset/copy Token.
# Message Content intent must be enabled there too.
DISCORD_BOT_TOKEN=
# Channel ID: enable Developer Mode (User Settings -> Advanced), then
# right-click the channel -> Copy Channel ID. All pundit + Hi-Lo messages
# for every fixture go to this one channel.
DISCORD_CHANNEL_ID=
# Optional: your test server's guild ID (right-click server icon -> Copy
# Server ID). If set, slash commands sync instantly instead of taking up to
# an hour globally -- recommended while developing/demoing.
DISCORD_GUILD_ID=
# Used by app/web.py's status page "Join the Discord" button. Create a
# never-expiring invite: Server Settings -> Invites -> Create Invite. Not a
# secret.
DISCORD_INVITE_URL=

# Phase 5 deployment only (see docs/DEPLOY.md) -- leave all of these blank
# for local dev, which uses onboarding/credentials.json + a local SQLite
# file instead.
#
# Postgres DSN (e.g. a free Neon project). When set, app/storage.py uses
# asyncpg instead of aiosqlite -- for hosts with no persistent disk.
DATABASE_URL=
# Redirects the local SQLite file + credentials.json under this directory
# instead (a host with a persistent volume mounts it there). Mutually
# exclusive in practice with DATABASE_URL -- pick whichever your host gives you.
DATA_DIR=
# Fallback source for TxLINE credentials when no local credentials.json
# exists: paste that file's entire contents here as one value. For hosts
# with no persistent disk to have kept the file onboarding originally wrote.
TXLINE_CREDENTIALS_JSON=
